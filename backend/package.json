{
    "name":  "electronic-rental-backend",
    "version":  "1.0.0",
    "description":  "Backend for electronic rental platform",
    "main":  "server.js",
    "scripts":  {
                    "start":  "node server.js",
                    "dev":  "nodemon server.js",
                    "test":  "npx vitest run",
                    "test:watch":  "npx vitest",
                    "test:coverage":  "npx vitest run --coverage",
                    "seed:products":  "node scripts/seedProducts.js",
                    "seed:full":  "node scripts/seedFullDataset.js",
                    "test:jest":  "npx jest --runInBand --config jest.config.js",
                    "test:jest:coverage":  "npx jest --runInBand --coverage --config jest.config.js"
                },
    "keywords":  [
                     "rental",
                     "electronics",
                     "mern"
                 ],
    "author":  "",
    "license":  "ISC",
    "dependencies":  {
                         "bcryptjs":  "^2.4.3",
                         "cors":  "^2.8.5",
                         "dotenv":  "^16.3.1",
                         "express":  "^4.18.2",
                         "express-validator":  "^7.0.1",
                         "jsonwebtoken":  "^9.0.2",
                         "mongoose":  "^7.5.0",
                         "nodemailer":  "^6.9.5",
                         "razorpay":  "^2.9.2",
                         "twilio":  "^4.16.0"
                     },
    "devDependencies":  {
                            "@vitest/coverage-v8":  "^4.0.18",
                            "jest":  "^30.2.0",
                            "nodemon":  "^3.0.1",
                            "supertest":  "^7.2.2"
                        }
}
